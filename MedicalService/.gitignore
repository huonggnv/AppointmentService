## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[Lg]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user files
/MedicalRecordService.Api/Properties/launchSettings.json.user

# Gemini / AI tools
.gemini/

# SQL Server files
*.mdf
*.ldf
*.ndf

# JetBrains Rider
.idea/
*.sln.iml

# OS files
.DS_Store
Thumbs.db
